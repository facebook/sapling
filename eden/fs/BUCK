load("@fbsource//tools/build_defs:default_platform_defs.bzl", "get_host_target_platform")
load("@fbsource//tools/build_defs:rust_binary.bzl", "rust_binary")

oncall("scm_client_infra")

cpp_library(
    name = "config",
    headers = ["eden-config.h"],
    exported_deps = [
        "//common/base:build_info_values",
    ],
)

# Universal (x86_64 + arm64) binary targets for macOS packaging.
# rust_universal_binary works for both Rust and C++ executables. Python PARs
# are packaged behind a universal native shim with separate arm64/x86_64 PARs.

rust_binary(
    name = "mac_python_par_shim",
    srcs = ["facebook/packaging/mac_python_par_shim.rs"],
    compatible_with = ["ovr_config//os:macos"],
    crate = "mac_python_par_shim",
    crate_root = "facebook/packaging/mac_python_par_shim.rs",
    unittests = False,
)

rust_universal_binary(
    name = "mac_python_par_shim_universal",
    source = ":mac_python_par_shim",
)

fbcode_configured_alias(
    name = "edenfsctl_real_macos_arm64",
    actual = "//eden/fs/cli:edenfsctl",
    compatible_with = ["ovr_config//os:macos"],
    default_target_platform = get_host_target_platform(use_minimal_xcode = True),
    platform = "ovr_config//platform/macos:arm64-fbsource-minimal",
    visibility = [],
)

fbcode_configured_alias(
    name = "edenfsctl_real_macos_x86_64",
