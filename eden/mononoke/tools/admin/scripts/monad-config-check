#!/bin/bash
# monad-config-check — wrapper around `mononoke_admin config check` that
# sets up a local-configerator-path layout from the user's configerator
# working copy, then invokes the subcommand.
#
# Why this wrapper:
#   `mononoke_admin --local-configerator-path <dir>` expects files at
#   `<dir>/<configerator-key>` (no extension), but a configerator
#   working copy stores them at
#   `<root>/materialized_configs/<key>.materialized_JSON`. This script
#   builds a temp dir of symlinks in the expected layout and invokes
#   mononoke_admin against it.
#
# By default it validates against the `mononoke.admin` fbpkg matching the
# OLDEST Mononoke config parser deployed in prod (via monad-admin-resolve),
# so a config that would crash the oldest deployed server on hot-reload is
# caught locally before `jf submit`. Pass `--local` (or set
# MONAD_CHECK_LOCAL=1) to validate against the `mononoke_admin` on your PATH
# instead — faster for local iteration, but only tells you it parses on
# trunk.
#
# Usage (from any configerator working copy, after `conf build`):
#
#   sl status | monad-config-check --stdin
#   monad-config-check --repo aosp/manifest
#   monad-config-check --from-changed-files /tmp/paths.txt
#   monad-config-check --local --repo aosp/manifest   # skip version match
#
# Env overrides:
#   MONONOKE_ADMIN_BIN   explicit mononoke_admin binary; when set, skips
#                        version resolution and uses it verbatim
#   MONAD_CHECK_LOCAL    =1 to validate against the PATH binary (same as --local)
#   CONFIGERATOR_ROOT    configerator working-copy root (default: cwd if it contains materialized_configs/, else error)
#   MONAD_CHECK_TIER     tier to load against (default: scs)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RESOLVER="$SCRIPT_DIR/monad-admin-resolve"
TIER="${MONAD_CHECK_TIER:-scs}"

# Pull `--local` out of the argument list before it reaches `config check`.
LOCAL=0
ARGS=()
for a in "$@"; do
    case "$a" in
        --local) LOCAL=1 ;;
        *) ARGS+=("$a") ;;
    esac
done
set -- ${ARGS[@]+"${ARGS[@]}"}

# Resolve which mononoke_admin binary to validate against.
#   1. explicit MONONOKE_ADMIN_BIN wins
#   2. --local / MONAD_CHECK_LOCAL=1 → PATH binary (fast, trunk-only)
#   3. default → version-matched admin via monad-admin-resolve, with a loud
#      fall back to the PATH binary if resolution fails (never hard-blocks)
if [[ -n "${MONONOKE_ADMIN_BIN:-}" ]]; then
    ADMIN_BIN="$MONONOKE_ADMIN_BIN"
    echo "monad-config-check: using MONONOKE_ADMIN_BIN=$ADMIN_BIN" >&2
elif [[ "$LOCAL" == "1" || "${MONAD_CHECK_LOCAL:-0}" == "1" ]]; then
    ADMIN_BIN="mononoke_admin"
    echo "monad-config-check: --local: validating against mononoke_admin on PATH (trunk, not oldest deployed prod)" >&2
elif RESOLVED="$("$RESOLVER")" && "$RESOLVED" config check --help >/dev/null 2>&1; then
    # The version-matched admin exists AND supports `config check`. (The
    # subcommand shipped in D110083435; an admin older than that landing
    # won't have it — see the probe fall-through below.)
    ADMIN_BIN="$RESOLVED"
    echo "monad-config-check: version-matched admin: $ADMIN_BIN" >&2
elif [[ -n "${RESOLVED:-}" ]]; then
    # Resolution succeeded but the matched admin predates the `config check`
    # subcommand. Fall back to PATH. This self-heals once D110083435
    # propagates to the oldest deployed Mononoke (then the matched admin has
    # the subcommand).
    ADMIN_BIN="mononoke_admin"
    echo "monad-config-check: WARNING: version-matched admin ($RESOLVED) predates the 'config check' subcommand (D110083435); falling back to mononoke_admin on PATH, which validates against TRUNK, not the oldest deployed prod binary. This self-heals once D110083435 propagates. Pass --local to silence." >&2
else
    ADMIN_BIN="mononoke_admin"
    echo "monad-config-check: WARNING: could not resolve the version-matched admin; falling back to mononoke_admin on PATH. This validates against TRUNK, not the oldest deployed prod binary. Pass --local to silence this warning." >&2
fi

# Resolve configerator root.
if [[ -n "${CONFIGERATOR_ROOT:-}" ]]; then
    ROOT="$CONFIGERATOR_ROOT"
elif [[ -d "./materialized_configs" ]]; then
    ROOT="$(pwd)"
else
    echo "error: not in a configerator working copy (no ./materialized_configs)." >&2
    echo "       cd into your configerator checkout or set CONFIGERATOR_ROOT=<path>." >&2
    exit 2
fi

if [[ ! -d "$ROOT/materialized_configs/scm/mononoke/repos/tiers" ]]; then
    echo "error: $ROOT/materialized_configs/scm/mononoke/repos/tiers does not exist." >&2
    echo "       Have you run \`conf build\` yet?" >&2
    exit 2
fi

# Build the symlink layout under a temp dir. ConfigStore::file serves files
# at <root>/<configerator-key>, so we strip the `.materialized_JSON` suffix
# and drop the `materialized_configs/` prefix.
TMPDIR="$(mktemp -d -t monad-config-check.XXXXXX)"
trap 'rm -rf "$TMPDIR"' EXIT

# Mirror everything under materialized_configs/scm/mononoke/. The
# RepoFactory facet build reads from several paths beyond
# repos/ (redaction sets, hooks, blobstore configs, etc.) — listing
# them explicitly is fragile, so just symlink the whole subtree.
# Cost: ~10k symlinks, ~3s on a warm cache.
count=0
src="$ROOT/materialized_configs/scm/mononoke"
if [[ -d "$src" ]]; then
    while IFS= read -r -d '' f; do
        rel="${f#"$ROOT"/materialized_configs/}"
        target="$TMPDIR/${rel%.materialized_JSON}"
        mkdir -p "$(dirname "$target")"
        ln -s "$f" "$target"
        count=$((count + 1))
    done < <(find "$src" -name "*.materialized_JSON" -print0)
fi

echo "monad-config-check: linked $count materialized configs from $ROOT to $TMPDIR" >&2

exec "$ADMIN_BIN" \
    --config-tier "$TIER" \
    --local-configerator-path "$TMPDIR" \
    config check "$@"
