load("@fbsource//tools/build_defs:rust_library.bzl", "rust_library")

oncall("scm_server_treehugger")

rust_library(
    name = "scs_client_raw",
    srcs = glob(["src/**/*.rs"]),
    allow_oss_build = False,
    autocargo = {"ignore_rule": True},
    # Not a public library.
    # Use fbcode/scm/scmquery/client/src/lib.rs instead
    visibility = [
        "//eden/...",
        "//scm/...",
        # Allow only existing use cases
        "//devai/config/loader_rs/...",
        "//devai/devmate_client/...",
        # trajectory_insights uses SCS to fetch the bytes of source
        # files at the commit of a Phabricator diff version so it can
        # populate `code_snippet` for inline review comments without an
        # attached Suggest Edit (the diff hunk text otherwise lives in
        # Everstore and isn't directly Hive-queryable). See
        # `fbcode/devai/trajectory_insights/src/file_snippets.rs`.
        "//devai/trajectory_insights/...",
        "//atlas/lib/rust/capabilities/...",
        "//vscode_native/...",
    ],
    deps = [
        "fbsource//third-party/rust:anyhow",
        "fbsource//third-party/rust:maplit",
        "//c2p/secure_thrift/rust/client:x2pclient",
        "//common/rust/shed/fbinit:fbinit",
        "//eden/mononoke/cmdlib/sharding_ext:sharding_ext",
        "//eden/mononoke/scs/if:source_control-rust",
        "//eden/mononoke/scs/if:source_control-rust-clients",
        "//eden/mononoke/scs/if:source_control-rust-x2pclients",
        "//eden/scm/lib/clientinfo:clientinfo",
    ] + select({
        "DEFAULT": [],
        "ovr_config//os:linux": [
            "//common/rust/identity:identity",
            "//common/rust/thrift/srclient:srclient",
            "//eden/mononoke/scs/if:source_control-rust-srclients",
            "//eden/mononoke/scs/if:source_control-rust-thriftclients",
        ],
        "ovr_config//os:macos": [
            "//common/rust/identity:identity",
            "//eden/mononoke/scs/if:source_control-rust-thriftclients",
        ],
    }),
)
