load("@fbcode_macros//build_defs:python_binary.bzl", "python_binary")
load("@fbsource//tools/target_determinator/macros:ci.bzl", "ci")
load("//fbpkg:fbpkg.bzl", "fbpkg")

oncall("scm_server_treehugger")

python_binary(
    name = "merge_resolution_blame_checker",
    srcs = ["merge_resolution_blame_checker.py"],
    main_function = "eden.mononoke.scripts.merge_resolution_blame_checker.main",
    deps = [
        "//libfb/py:employee",
        "//libfb/py/thrift_clients:oncall_thrift_client",
        "//phabricator:new_phabricator_graphql_helpers",
        "//phabricator:phabricator_authentication",
        "//phabricator:phabricator_graphql_client",
        "//rfe/py/lib:sql",
        "//rfe/scubadata:scubadata_py3",
    ],
)

fbpkg.builder(
    name = "mononoke.merge_resolution_blame_checker",
    buck_opts = fbpkg.buck_opts(
        mode = "opt",
    ),
    path_actions = {
        "merge_resolution_blame_checker": ":merge_resolution_blame_checker",
    },
)

python_binary(
    name = "canary_shard_pin",
    srcs = ["canary_shard_pin.py"],
    # Transitive SM/polyglot deps don't build under dev-rust-oss; drop that mode
    # from CI (the target builds fine in the default/opt modes).
    labels = ci.remove_labels(ci.mode("fbcode//mode/dev-rust-oss")),
    main_function = "eden.mononoke.scripts.canary_shard_pin.main",
    deps = [
        "//libfb/py/shardmanager:structs",
        "//libfb/py/shardmanager/client_factory:smclient",
        "//shardmanager/smcli:param",
    ],
)

fbpkg.builder(
    name = "mononoke.canary_shard_pin",
    buck_opts = fbpkg.buck_opts(
        mode = "opt",
    ),
    path_actions = {
        "canary_shard_pin": ":canary_shard_pin",
    },
)
