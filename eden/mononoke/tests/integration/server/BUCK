load(
    "//eden/mononoke/tests/integration/facebook:fb_manifest_deps.bzl",
    "dott_test",
)

oncall("scm_server_treehugger")

dott_test(
    name = "server",
    # These tests have been vetted to run well without network access. Please investigate any failure thoroughly before disabling.
    disable_all_network_access_target = True,
    dott_files = glob(
        [
            "*.t",
        ],
        exclude = [
            # Pessimistic locking requires MySQL (SQLite deadlocks
            # because LockedBookmarkTransaction holds the single
            # shared connection during rebase).
            "test-pushrebase-pessimistic-locking.t",
            "test-pushrebase-pessimistic-locking-stack.t",
        ],
    ),
    deps = [
        "//eden/mononoke:mononoke",
        # TODO: This is required for test-getpackv2-multibyte-filenames.t, as
        # hg can't handle UTF-8 file names correctly. Once that is fixed, this
        # dep can be removed.
        "//eden/mononoke/git/gitimport:gitimport",
        "//eden/mononoke/tests/integration:urlencode",
        "//eden/mononoke/tools/admin:admin",
        "//eden/mononoke/tools/testtool:testtool",
        "//eden/mononoke/jobs/blobstore_healer:blobstore_healer",
        "//eden/mononoke/tools/backfill_mapping:backfill_mapping",
    ],
)

dott_test(
    name = "server-mysql",
    # These tests have been vetted to run well without network access. Please investigate any failure thoroughly before disabling.
    disable_all_network_access_target = True,
    dott_files = [
        "test-infinitepush-mutation.t",
        "test-pushrebase.t",
        "test-pushrebase-per-bookmark-locking.t",
        "test-pushrebase-per-bookmark-locking-conflict.t",
        "test-pushrebase-per-bookmark-locking-shadow.t",
        "test-pushrebase-per-bookmark-locking-stack.t",
        "test-server-init.t",
        "test-server-lookup.t",
    ],
    use_mysql = True,
    deps = [
        "//eden/mononoke:mononoke",
        "//eden/mononoke/tools/admin:admin",
        "//eden/mononoke/tools/testtool:testtool",
    ],
)

# Pessimistic locking tests are heavy (SQL locks + full pushrebase) and
# time out in dev-rust-oss debug builds. Run only in fbcode opt builds.
dott_test(
    name = "server-mysql-pessimistic",
    disable_all_network_access_target = True,
    dott_files = [
        "test-pushrebase-pessimistic-locking.t",
        "test-pushrebase-pessimistic-locking-stack.t",
    ],
    rust_allow_oss_build = False,
    use_mysql = True,
    deps = [
        "//eden/mononoke:mononoke",
        "//eden/mononoke/tools/admin:admin",
        "//eden/mononoke/tools/testtool:testtool",
    ],
)
