Verify we load internalconfig during clone
  $ cd $TESTTMP
  $ export HG_TEST_INTERNALCONFIG="$TESTTMP/test_hgrc"
  $ cat > test_hgrc <<EOF
  > [hooks]
  > post-clone.foo = printf "Hook ran!\n"
  > EOF
Clear the cached, non-repo dynamic config
  $ rm -rf $TESTTMP/.cache 
  $ cat > good_hgrc <<EOF
  > [foo]
  > bar=True
  > EOF
  $ sl clone test:server client2 --configfile $TESTTMP/good_hgrc
  Cloning server into $TESTTMP/client2
  Server has no 'master' bookmark - trying tip.
  Checking out 'tip'
  Hook ran!
  $ cat client2/.sl/hgrc.dynamic
  # version=* (glob)
  # reponame=* (glob)
  # canary=None
  # username=
  # Generated by `sl debugrefreshconfig` - DO NOT MODIFY
  [hooks]
  post-clone.foo=printf "Hook ran!\n"
  
Verify hgrc.dynamic is updated even if the original command is outside the repo
  $ echo "[junk_on_the_end]" >> client2/.sl/hgrc.dynamic
  $ sleep 1
  $ sl -R client2 status --config configs.generationtime=1
  $ sleep 1
  $ cat client2/.sl/hgrc.dynamic
  # version=* (glob)
  # reponame=* (glob)
  # canary=None
  # username=
  # Generated by `* debugrefreshconfig` - DO NOT MODIFY (glob)
