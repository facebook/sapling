#inprocess-hg-incompatible
#require no-eden
  $ configure modernclient

  $ export HG_TEST_INTERNALCONFIG="$TESTTMP/test_hgrc"
  $ cat > test_hgrc <<EOF
  > [section]
  > key=value
  > EOF

Outside of repo the dynamic config gets written to a known global spot.

  $ sl help > /dev/null

  $ cat $TESTTMP/.cache/edenscm/hgrc.dynamic
  # version=* (glob)
  # reponame=* (glob)
  # canary=None
  # username=
  # Generated by `sl debugrefreshconfig` - DO NOT MODIFY
  [section]
  key=value
  

debugdumpinternalconfig works without a repo

  $ sl debugdumpinternalconfig
  [section]
  key=value
  
  $ sl debugdumpinternalconfig section.key
  value

Create a repo

  $ newclientrepo client

Verify it can be manually generated

  $ sl debugrefreshconfig
  $ cat .sl/hgrc.dynamic
  # version=* (glob)
  # reponame=* (glob)
  # canary=None
  # username=
  # Generated by `sl debugrefreshconfig` - DO NOT MODIFY
  [section]
  key=value
  
  $ sl config section.key
  value

Verify it can be automatically synchronously generated

  $ rm .sl/hgrc.dynamic
  $ sl config section.key
  value
  $ cat .sl/hgrc.dynamic
  # version=* (glob)
  # reponame=client_server
  # canary=None
  # username=
  # Generated by `sl debugrefreshconfig` - DO NOT MODIFY
  [section]
  key=value
  
#if no-windows
  $ f -m .sl/hgrc.dynamic
  .sl/hgrc.dynamic: mode=644
#endif

Verify it can be automatically asynchronously regenerated

  $ cat > $TESTTMP/test_hgrc <<EOF
  > [section]
  > key=value
  > [section2]
  > key2=value2
  > EOF
  $ sl config section2.key2 --config configs.generationtime=30 # No regen, because too soon
  [1]
  $ sleep 1
  $ sl status --config configs.generationtime=1 # Regen, because lower time limit
  $ sleep 0.5 # Time for background process to complete
  $ sl config section2.key2
  value2
  $ cat .sl/hgrc.dynamic
  # version=* (glob)
  # reponame=* (glob)
  # canary=None
  # username=
  # Generated by `sl debugrefreshconfig` - DO NOT MODIFY
  [section]
  key=value
  
  [section2]
  key2=value2
  
Verify mtime is updated even if no change is made
  $ sl debugsh -c "import stat, os; ui.write('%s\n' % os.stat(os.path.join('.sl', 'hgrc.dynamic'))[stat.ST_MTIME])" > $TESTTMP/mtime1
  $ sl status --config configs.generationtime=60 # No regen, because high time limit
  $ sl debugsh -c "import stat, os; ui.write('%s\n' % os.stat(os.path.join('.sl', 'hgrc.dynamic'))[stat.ST_MTIME])" > $TESTTMP/mtime2
  $ [ "$(cat $TESTTMP/mtime1)" = "$(cat $TESTTMP/mtime2)" ]

  $ sleep 1
  $ sl status --config configs.generationtime=1 # Regen, because low time limit
  $ sl debugsh -c "import stat, os; ui.write('%s\n' % os.stat(os.path.join('.sl', 'hgrc.dynamic'))[stat.ST_MTIME])" > $TESTTMP/mtime3
  $ [ "$(cat $TESTTMP/mtime3)" = "$(cat $TESTTMP/mtime2)" ]
  [1]

